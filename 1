--功速帳號問題
task.spawn(function()
    local ATTACK_RANGE = 5000    -- 推薦 250~350
    local MAX_TARGETS = 8       -- 建議 6~10，不要超過12
    local lastSeedUpdate = 0
    local currentRemote = nil
    local currentId = nil

    local Net = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")

    local function UpdateRemoteAndSeed()
        if tick() - lastSeedUpdate < 0.45 then return end
        currentRemote = nil
        currentId = nil
        for _, folder in ipairs({ReplicatedStorage.Util, ReplicatedStorage.Common, ReplicatedStorage.Remotes, ReplicatedStorage.Assets, ReplicatedStorage.FX}) do
            for _, v in ipairs(folder:GetChildren()) do
                if v:IsA("RemoteEvent") and v:GetAttribute("Id") then
                    currentRemote = v
                    currentId = v:GetAttribute("Id")
                    break
                end
            end
            if currentRemote then break end
        end
        lastSeedUpdate = tick()
    end

    local function GetNearbyParts()
        local parts = {}
        local character = player.Character
        if not character then return parts end
        local root = character:FindFirstChild("HumanoidRootPart")
        if not root then return parts end

        for _, folder in ipairs({workspace.Enemies, workspace.Characters}) do
            for _, v in ipairs(folder:GetChildren()) do
                local hrp = v:FindFirstChild("HumanoidRootPart")
                local hum = v:FindFirstChild("Humanoid")
                if v ~= character and hrp and hum and hum.Health > 0 then
                    local distance = (hrp.Position - root.Position).Magnitude
                    if distance <= ATTACK_RANGE then
                        for _, part in ipairs(v:GetChildren()) do
                            if part:IsA("BasePart") then
                                table.insert(parts, {v, part})
                            end
                        end
                    end
                end
            end
        end
        return parts
    end

    while task.wait(0.032) do
        if not _G.FatAttackEnabled then
            task.wait(0.1)
            continue
        end

        pcall(function()
            UpdateRemoteAndSeed()

            local character = player.Character
            if not character then return end

            local tool = character:FindFirstChildOfClass("Tool")
            if not tool then return end
            if tool:GetAttribute("WeaponType") ~= "Melee" and tool:GetAttribute("WeaponType") ~= "Sword" then return end

            local allParts = GetNearbyParts()
            if #allParts == 0 then return end

            local attackParts = {}
            for i = 1, math.min(MAX_TARGETS, #allParts) do
                table.insert(attackParts, allParts[i])
            end

            local mainTarget = attackParts[1][1]
            local mainHead = mainTarget:FindFirstChild("Head") or attackParts[1][2]

            Net["RE/RegisterAttack"]:FireServer()
            Net["RE/RegisterHit"]:FireServer(mainHead, attackParts, {}, "")

            if currentRemote and currentId then
                local encryptedName = string.gsub("RE/RegisterHit", ".", function(c)
                    local shift = math.floor(workspace:GetServerTimeNow() / 10 % 10) + 1
                    return string.char(bit32.bxor(string.byte(c), shift))
                end)

                local seed = Net.seed:InvokeServer()
                local encryptedId = bit32.bxor(currentId + 909090, seed * 2)

                cloneref(currentRemote):FireServer(encryptedName, encryptedId, mainHead, attackParts)
            end
        end)
    end
end)

