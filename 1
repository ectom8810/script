-- 懸浮球拖動功能
local dragging = false
local dragStart, startPos
local dragThreshold = 15  -- [修正] 加大門檻，避免手機輕觸被誤判成拖動

floatBall.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end  -- [修正] 過濾遊戲搖桿/跳躍等UI誤觸
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = floatBall.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    -- 注意：這裡不加 gameProcessed 過濾，否則拖動會卡頓
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        floatBall.Position = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X, 
            startPos.Y.Scale, 
            startPos.Y.Offset + delta.Y
        )
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if dragging then
            dragging = false
            if (input.Position - dragStart).Magnitude < dragThreshold then
                toggleUI()
            end
        end
    end
end)

