local function startAutoUp(fromB)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp or hrp:FindFirstChild("UpLoop") then return end
    _upActive = true
    if fromB then _upByB = true end
    local flag = Instance.new("BoolValue", hrp)
    flag.Name = "UpLoop"
    task.spawn(function()
        while flag.Parent do
            local h = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if not h then break end
            h.CFrame = h.CFrame * CFrame.new(0, 100000, 0)
            task.wait(0.05)
        end
        _upActive = false
        _upByB = false
    end)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Escape";
        Text = "On";
        Icon = "";
        Duration = 5;
    })
end

local function stopAutoUp()
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        local flag = hrp:FindFirstChild("UpLoop")
        if flag then flag:Destroy() end
    end
    _upActive = false
    _upByB = false
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Escape";
        Text = "Off";
        Icon = "";
        Duration = 5;
    })
end

