-- 加強版找目標（最近優先 + 無限距離 + 持續鎖定）
function FlashAttack:FindTarget()
    local char = game.Players.LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    
    local myPos = char.HumanoidRootPart.Position
    
    -- 如果已經有鎖定目標且還活著，就優先繼續打他
    if self.CurrentTarget and self.CurrentTarget.Parent and self.CurrentTarget:FindFirstChild("Humanoid") and self.CurrentTarget.Humanoid.Health > 0 then
        return self.CurrentTarget
    end

    local nearest = nil
    local nearestDist = math.huge

    for _, folder in ipairs({workspace.Enemies, workspace.Characters}) do
        if not folder then continue end
        for _, model in ipairs(folder:GetChildren()) do
            local hrp = model:FindFirstChild("HumanoidRootPart")
            local hum = model:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 and model ~= char then
                local dist = (hrp.Position - myPos).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearest = hrp
                end
            end
        end
    end

    self.CurrentTarget = nearest
    return nearest
end

function FlashAttack:Attack()
    if not _G.FlashAttackEnabled or (tick() - self.Debounce) < 0.005 then return end   -- 更快一點
    
    local char = game.Players.LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    if not self:HasBloxFruit() then 
        pick_ca_bon()
        return 
    end

    local targetHRP = self:FindTarget()
    if not targetHRP then return end

    local hrp = char.HumanoidRootPart
    local direction = (targetHRP.Position - hrp.Position).Unit

    -- LeftClickRemote
    local leftRemote = self:FindRemote()
    if leftRemote then
        pcall(function() leftRemote:FireServer(direction, 1) end)
    end

    -- XOR Fast Attack
    if self:FindFastAttackRemote() and self.Remote and self._FA_idremote then
        pcall(function()
            local net = game:GetService("ReplicatedStorage").Modules.Net
            if net and net.seed then
                local encName = string.gsub("RE/RegisterHit", ".", function(c)
                    return string.char(bit32.bxor(string.byte(c), math.floor(workspace:GetServerTimeNow()/10 %10) +1))
                end)
                
                local encId = bit32.bxor(self._FA_idremote + 909090, net.seed:InvokeServer() * 2)

                self.Remote:FireServer(encName, encId, targetHRP, {{targetHRP, targetHRP}})
            end
        end)
    end

    self.Debounce = tick()
end

